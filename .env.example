# Gemini Flash API key — get from https://aistudio.google.com/
GEMINI_API_KEY=

# Google Sheets — the ID is in the sheet URL:
# https://docs.google.com/spreadsheets/d/<SHEETS_ID>/edit
GOOGLE_SHEETS_ID=

# service account from google cloud console, navigate to that project, IAM and admin> Service Accounts> Create Service Account> Name it anything you want> Create and Download Key> Rename it to service-account.json and place it in the project root
# Path to the GCP service account JSON key file (place it in the project root)
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./service-account.json

# WhatsApp group JID — run `node scripts/list-groups.js` to find this
# Format: XXXXXXXXX-XXXXXXXXXX@g.us
TARGET_GROUP_JID=

# Email address to receive alerts when the WhatsApp session fails
ALERT_EMAIL=

# SMTP config — Brevo free tier: smtp-relay.brevo.com port 587
SMTP_HOST=smtp-relay.brevo.com
SMTP_USER=
SMTP_PASS=

# Port for the /health endpoint (UptimeRobot will ping this)
HEALTH_PORT=3000
